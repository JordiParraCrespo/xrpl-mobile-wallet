    "expo-linking": "~8.0.11",
    "expo-router": "~6.0.23",
    "expo-secure-store": "~15.0.0",
    "expo-status-bar": "~3.0.0",
    "lucide-react-native": "^0.577.0",
    "nativewind": "^4.2.2",
    "react": "19.1.0",
    "react-native": "0.81.5",
    "react-native-css-interop": "^0.2.3",
