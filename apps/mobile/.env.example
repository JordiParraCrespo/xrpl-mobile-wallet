# API
# Use http://localhost:3001 for the iOS simulator. On a physical device or
# Android emulator, point this at your machine's LAN IP (e.g. http://192.168.x.x:3001)
# and add that origin to the API's trusted origins if needed.
EXPO_PUBLIC_API_URL=http://localhost:3001

# Sentry
EXPO_PUBLIC_SENTRY_DSN=

# Dewy agent (POC) — Claude API key for the on-device wallet agent.
# Copy this file to apps/mobile/.env and fill it in, then restart Expo with
# `--clear`. NOTE: EXPO_PUBLIC_* values are inlined into the app bundle and are
# therefore extractable — fine for a testnet POC, move server-side before prod.
EXPO_PUBLIC_ANTHROPIC_API_KEY=
