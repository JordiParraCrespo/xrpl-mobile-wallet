{
  "name": "@flama/api",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "build": "nest build",
    "dev": "nest start --watch",
    "start": "node dist/main",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/main",
    "lint": "biome check src/",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "typeorm": "typeorm-ts-node-commonjs",
    "migration:generate": "pnpm typeorm migration:generate -d src/config/data-source.ts",
    "migration:run": "pnpm typeorm migration:run -d src/config/data-source.ts",
    "migration:revert": "pnpm typeorm migration:revert -d src/config/data-source.ts",
    "seed": "ts-node src/database/seed.ts",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@flama/backend-cache": "workspace:*",
    "@flama/backend-core": "workspace:*",
    "@flama/backend-email": "workspace:*",
    "@flama/backend-queue": "workspace:*",
    "@flama/backend-storage": "workspace:*",
    "@flama/shared": "workspace:*",
    "@nestjs/bullmq": "^11.0.0",
    "@nestjs/common": "^11.0.0",
    "@nestjs/config": "^4.0.0",
    "@nestjs/core": "^11.0.0",
    "@nestjs/event-emitter": "^3.0.0",
    "@nestjs/jwt": "^11.0.0",
    "@nestjs/passport": "^11.0.0",
    "@nestjs/platform-express": "^11.0.0",
    "@nestjs/swagger": "^11.0.0",
    "@nestjs/terminus": "^11.0.0",
    "@nestjs/throttler": "^6.0.0",
    "@nestjs/typeorm": "^11.0.0",
    "@sentry/nestjs": "^9.0.0",
    "bcrypt": "^6.0.0",
    "bullmq": "^5.0.0",
    "class-transformer": "^0.5.1",
    "helmet": "^8.0.0",
    "ioredis": "^5.4.0",
    "nestjs-pino": "^4.0.0",
    "nestjs-zod": "^4.0.0",
    "passport": "^0.7.0",
    "passport-github2": "^0.1.12",
    "passport-google-oauth20": "^2.0.0",
    "passport-jwt": "^4.0.1",
    "passport-local": "^1.0.0",
    "pg": "^8.13.0",
    "pino-http": "^10.0.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.0",
    "typeorm": "^0.3.20",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@flama/config": "workspace:^",
    "@nestjs/cli": "^11.0.0",
    "@nestjs/schematics": "^11.0.0",
    "@nestjs/testing": "^11.0.0",
    "@types/bcrypt": "^5.0.0",
    "@types/express": "^5.0.6",
    "@types/multer": "^1.4.0",
    "@types/nodemailer": "^6.4.0",
    "@types/passport-github2": "^1.2.0",
    "@types/passport-google-oauth20": "^2.0.0",
    "@types/passport-jwt": "^4.0.0",
    "@types/passport-local": "^1.0.0",
    "testcontainers": "^10.0.0",
    "typescript": "^6.0.2",
    "unplugin-swc": "^1.5.9",
    "vitest": "^3.0.0"
  }
}
