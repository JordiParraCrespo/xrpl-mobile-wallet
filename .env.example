# Copy to `.env` and fill in. `.env` is git-ignored — never commit your real key.
#   cp .env.example .env

# Required for `pnpm demo:agent`. Get one at https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-...

# Optional: override the Claude model the agent uses (defaults to the SDK default).
# MODEL=claude-sonnet-4-6

# Optional: path to a markdown persona file (defaults to scripts/persona.example.md).
# PERSONA_FILE=scripts/persona.example.md
