{
  "name": "@flama/frontend",
  "version": "0.1.0",
  "private": true,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./di": {
      "types": "./dist/di/index.d.ts",
      "import": "./dist/di/index.js"
    },
    "./react": {
      "types": "./dist/react/index.d.ts",
      "import": "./dist/react/index.js"
    },
    "./state": {
      "types": "./dist/modules/auth/auth.state.d.ts",
      "import": "./dist/modules/auth/auth.state.js"
    }
  },
  "peerDependencies": {
    "@tanstack/react-query": "^5.0.0",
    "react": "^18.0.0 || ^19.0.0"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    },
    "@tanstack/react-query": {
      "optional": true
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsc -p tsconfig.json --watch",
    "clean": "rm -rf dist",
    "lint": "biome check src/",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@flama/api-client": "workspace:*",
    "@flama/chain-core": "workspace:*",
    "@flama/chain-evm": "workspace:*",
    "@flama/chain-xrpl": "workspace:*",
    "@flama/shared": "workspace:*",
    "@flama/wallet-keyring": "workspace:*",
    "@tanstack/query-core": "^5.62.0",
    "better-auth": "^1.6.14",
    "inversify": "^7.0.0",
    "reflect-metadata": "^0.2.2",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "@flama/config": "workspace:^",
    "@types/react": "^19.0.0",
    "typescript": "^6.0.2",
    "vitest": "^3.0.0"
  }
}
